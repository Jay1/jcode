{
  "name": "jcode",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@8881a9b",
      "@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@8881a9b",
      "@effect/openapi-generator": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/openapi-generator@8881a9b",
      "@effect/sql-sqlite-bun": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/sql-sqlite-bun@8881a9b",
      "@effect/vitest": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/vitest@8881a9b",
      "@effect/language-service": "0.75.1",
      "@types/bun": "^1.3.9",
      "@types/node": "^25.9.1",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.1.7"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:web": "node scripts/dev-runner.ts dev:web",
    "dev:marketing": "turbo run dev --filter=@jcode/marketing",
    "dev:desktop": "node scripts/dev-runner.ts dev:desktop",
    "electron": "bun run start:desktop",
    "electron:dev": "node scripts/dev-runner.ts dev:desktop --home-dir ./.jcode/electron-dev",
    "start": "turbo run start --filter=@jcode/server",
    "start:desktop": "turbo run start --filter=@jcode/desktop",
    "start:marketing": "turbo run preview --filter=@jcode/marketing",
    "build": "turbo run build",
    "build:marketing": "turbo run build --filter=@jcode/marketing",
    "build:desktop": "turbo run build --filter=@jcode/desktop --filter=@jcode/server",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "test:local": "JCODE_LOCAL_TEST_PROFILE=1 turbo run test --concurrency=1 --ui=stream",
    "react-doctor": "react-doctor apps/web --yes --fail-on none",
    "react-doctor:changed": "react-doctor apps/web --yes --diff HEAD --fail-on warning",
    "test:all": "bun run test && bun run test:browser",
    "test:all:local": "bun run test:local && bun run test:browser:local",
    "test:browser": "turbo run test:browser --filter=@jcode/web",
    "test:browser:local": "JCODE_LOCAL_TEST_PROFILE=1 turbo run test:browser --filter=@jcode/web --concurrency=1 --ui=stream",
    "test:browser:install": "bun run --cwd apps/web test:browser:install",
    "test:browser:install:deps": "bun run --cwd apps/web test:browser:install:deps",
    "test:coverage": "turbo run test -- --coverage",
    "test:desktop-smoke": "turbo run smoke-test --filter=@jcode/desktop",
    "release:notes": "bun scripts/release-notes.ts",
    "release:scoop": "node scripts/generate-scoop-manifest.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fmt:check:local": "oxfmt --check --threads=4",
    "build:contracts": "turbo run build --filter=@jcode/contracts",
    "dist:desktop:artifact": "node scripts/build-desktop-artifact.ts",
    "dist:desktop:dmg": "node scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "node scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "node scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
    "dist:desktop:linux": "node scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
    "dist:desktop:win": "node scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
    "release:smoke": "node scripts/release-smoke.ts",
    "upstream:watch": "node scripts/upstream-watch.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules scripts/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "4.1.7",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "react-doctor": "^0.2.3",
    "turbo": "^2.9.16",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "^8.0.0"
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^26.2.0"
  },
  "packageManager": "bun@1.3.9",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  }
}
