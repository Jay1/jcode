{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "DPCODE_MODE",
    "JCODE_MODE",
    "JCODE_PORT",
    "JCODE_NO_BROWSER",
    "JCODE_HOME",
    "JCODE_AUTH_TOKEN",
    "JCODE_AUTO_BOOTSTRAP_PROJECT_FROM_CWD",
    "JCODE_LOG_PROVIDER_EVENTS",
    "JCODE_LOG_WS_EVENTS",
    "JCODE_DESKTOP_WS_URL",
    "JCODE_DESKTOP_MOCK_UPDATES",
    "JCODE_DISABLE_AUTO_UPDATE",
    "JCODE_LOCAL_TEST_PROFILE",
    "DPCODE_PORT",
    "DPCODE_NO_BROWSER",
    "DPCODE_HOME",
    "DPCODE_AUTH_TOKEN",
    "DPCODE_AUTO_BOOTSTRAP_PROJECT_FROM_CWD",
    "DPCODE_LOG_PROVIDER_EVENTS",
    "DPCODE_LOG_WS_EVENTS",
    "DPCODE_DESKTOP_WS_URL",
    "T3CODE_LOG_WS_EVENTS",
    "T3CODE_MODE",
    "T3CODE_PORT",
    "T3CODE_NO_BROWSER",
    "T3CODE_HOME",
    "T3CODE_AUTH_TOKEN",
    "T3CODE_AUTO_BOOTSTRAP_PROJECT_FROM_CWD",
    "T3CODE_LOG_PROVIDER_EVENTS",
    "T3CODE_DESKTOP_WS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@jcode/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "test:browser": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
